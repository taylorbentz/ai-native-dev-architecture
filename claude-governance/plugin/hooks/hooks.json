{
  "_comment": "Wires the shared safety hooks into every session the plugin is enabled in. ${CLAUDE_PLUGIN_ROOT} resolves to this plugin's install location, so the hooks work no matter where the plugin is installed.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-cwd.sh", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/validate-style.sh", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/check-uncommitted.sh", "timeout": 10 }
        ]
      }
    ]
  }
}
